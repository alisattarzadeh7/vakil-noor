{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/posts/layout,_N_T_/posts/new/layout,_N_T_/posts/new/page,_N_T_/posts/new"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/posts/new/__PAGE__",
    "/posts/new",
    "/posts",
    "/_index",
    "/_head"
  ]
}